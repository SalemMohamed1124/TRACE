# Database
DATABASE_URL=postgresql://viper:viper_secret@localhost:5434/viper

# JWT
JWT_SECRET=change-me-min-32-characters-long
JWT_REFRESH_SECRET=change-me-refresh-min-32-chars

# Redis
REDIS_HOST=localhost
REDIS_PORT=6380

# Google Gemini AI
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash-exp

# SMTP (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your-app-password

# Development
# Set to true for instant fake scan results (no real network requests)
# Set to false (or remove) for real scans against live targets
SCAN_MOCK_MODE=false

# Server
PORT=3001
FRONTEND_URL=http://localhost:3000
